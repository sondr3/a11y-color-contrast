{
	"name": "a11y-color-contrast",
	"version": "0.2.0",
	"description": "A simple utility package for working with WCAG 2.2/3.0 color contrasts",
	"keywords": [
		"a11y",
		"apca",
		"color",
		"contrast",
		"wcag"
	],
	"homepage": "https://github.com/sondr3/a11y-color-contrast#readme",
	"bugs": {
		"url": "https://github.com/sondr3/a11y-color-contrast/issues"
	},
	"license": "MIT",
	"author": "Sondre Aasemoen <sondre@eons.io> (https://www.eons.io)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sondr3/a11y-color-contrast.git"
	},
	"files": [
		"src",
		"dist",
		"LICENSE",
		"README.md",
		"CHANGELOG.md",
		"package.json"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		"default": "./dist/index.js",
		"types": "./dist/index.d.ts"
	},
	"scripts": {
		"prepare": "lefthook install",
		"dev": "tsc --watch --incremental",
		"build": "rm -rf ./dist && tsc",
		"release": "rm -rf ./dist && tsc -p tsconfig.release.json",
		"format": "oxfmt",
		"format:fix": "oxfmt --fix",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix .",
		"test": "vitest",
		"coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@sondr3/oxfmt": "0.1.2",
		"@sondr3/oxlint": "0.1.1",
		"@sondr3/tsconfig": "0.10.0",
		"@types/node": "26.0.0",
		"@vitest/coverage-v8": "4.1.9",
		"lefthook": "2.1.9",
		"oxfmt": "0.55.0",
		"oxlint": "1.70.0",
		"oxlint-tsgolint": "0.23.0",
		"typescript": "7.0.1-rc",
		"vitest": "4.1.9"
	},
	"engines": {
		"node": ">=26.0.0",
		"pnpm": ">=11.0.0"
	},
	"packageManager": "pnpm@11.8.0",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "26.3.1",
			"onFail": "download"
		}
	}
}
